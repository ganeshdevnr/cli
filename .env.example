# Focus Timer - Media Player Configuration
# Default: Windows Media Player
# MEDIA_PLAYER_PATH="C:\Program Files (x86)\Windows Media Player\wmplayer.exe"
# MEDIA_PLAYER_PATH="C:\Program Files\VLC\vlc.exe"

# Backup Tool - Vault Paths
# PERSONAL_VAULT_PATH=C:\github\Personal_Vault
# OFFICE_VAULT_PATH=C:\github\Office_Vault

# Password Generator - Output Directory
# Default: %USERPROFILE%\Documents\Generated Passwords
# PASSWORD_OUTPUT_DIR=C:\Users\YourName\Documents\Passwords
